# ============================================================================
#  Environment variables — copy this file to ".env" and fill in the values.
#  (.env is git-ignored and is read ONLY by the local Node script
#   `npm run github`. None of this is ever bundled into the website.)
# ============================================================================

# Your GitHub username (used to fetch your public repositories).
GITHUB_USERNAME=houssemeddine99

# OPTIONAL GitHub token.
#   • Public repos work WITHOUT a token — leave this blank and it still works.
#   • Add a token only to (a) raise the API rate limit, or (b) include private repos.
#   • Create one at: https://github.com/settings/tokens
#       - "Fine-grained" token with read-only access, OR
#       - "Classic" token with the `read:user` (and `repo` for private) scope.
#   • SECURITY: never commit a real token and never prefix it with VITE_
#     (VITE_ vars get bundled into the public site). This one stays local.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# OPTIONAL — Higgsfield Cloud API (AI video generation), used by `npm run video`.
# Create keys at https://cloud.higgsfield.ai/api-keys (you get a key + a secret).
# Auth is sent as:  Authorization: Key {HIGGSFIELD_API_KEY}:{HIGGSFIELD_SECRET}
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=

# Optional: override the prompt for the generated hero background video.
HERO_VIDEO_PROMPT=Cinematic abstract background, flowing neon cyan and purple particles on a dark backdrop, slow elegant motion, futuristic, seamless loop
